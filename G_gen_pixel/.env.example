# Google Maps API key — needs Maps JavaScript API + Geocoding API + Map Tiles API enabled
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# OpenAI API key — needs access to gpt-image-2 (images.edit endpoint)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: server port (default 5001)
# PORT=5001
